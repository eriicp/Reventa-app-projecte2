<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#F8F9FA">

    <TextView
        android:id="@+id/tvTituloVenta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vender Entrada"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvSubtitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Rellena los datos y sube tu PDF original. Se pondrá a la venta automáticamente."
        android:layout_marginTop="8dp"
        android:textColor="#757575"
        app:layout_constraintTop_toBottomOf="@id/tvTituloVenta"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvLabelEvento"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selecciona el Evento:"
        android:layout_marginTop="30dp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitulo"
        app:layout_constraintStart_toStartOf="parent" />

    <Spinner
        android:id="@+id/spinnerEventos"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:background="@android:drawable/btn_dropdown"
        app:layout_constraintTop_toBottomOf="@id/tvLabelEvento" />

    <TextView
        android:id="@+id/tvLabelPrecio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Precio de venta (€):"
        android:layout_marginTop="20dp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/spinnerEventos"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/etPrecioVenta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:inputType="numberDecimal"
        android:hint="Ej. 150.00"
        android:backgroundTint="#CCCCCC"
        app:layout_constraintTop_toBottomOf="@id/tvLabelPrecio" />

    <TextView
        android:id="@+id/tvLabelZona"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Zona (Ej: Pista, Grada Norte):"
        android:layout_marginTop="16dp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/etPrecioVenta"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/etZona"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Ej. Pista General"
        app:layout_constraintTop_toBottomOf="@id/tvLabelZona" />

    <LinearLayout
        android:id="@+id/layoutUbicacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/etZona">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fila:"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/etFila"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ej. 12 (o '-')" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Asiento:"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/etAsiento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ej. 34 (o '-')" />
        </LinearLayout>
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/btnSeleccionarPdf"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginTop="30dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#E3F2FD"
        app:layout_constraintTop_toBottomOf="@id/layoutUbicacion">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📁 Tocar para buscar PDF"
                android:textColor="#1976D2"
                android:textStyle="bold"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvNombreArchivo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Ningún archivo seleccionado"
                android:textColor="#555555"
                android:textSize="12sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnPublicarVenta"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Publicar Entrada"
        android:textSize="18sp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>