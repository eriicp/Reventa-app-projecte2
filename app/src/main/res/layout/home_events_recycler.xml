<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="150dp"
    android:layout_height="270dp"
    android:layout_marginStart="20dp"
    android:layout_marginEnd="20dp"
    android:layout_marginBottom="20dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="8dp"
    android:backgroundTint="#F2F2F4">

    <androidx.cardview.widget.CardView
        android:layout_width="150dp"
        android:layout_height="200dp"
        app:cardCornerRadius="20dp"
        >
    <FrameLayout
        android:layout_width="150dp"
        android:layout_height="200dp">

        <ImageView
            android:id="@+id/ivFeaturedEventBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/home_events_recycler_example" />

        <androidx.cardview.widget.CardView
            android:id="@+id/CVfeatureLabel"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_gravity="top"
            android:layout_marginStart="10dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/white"
            app:cardCornerRadius="10dp">

            <TextView
                android:id="@+id/tvMonthLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|center"
                android:layout_marginTop="5dp"
                android:text="JUN"
                android:textColor="@color/blue"
                android:textSize="14sp"
                android:textStyle="bold" />

        </androidx.cardview.widget.CardView>
    </FrameLayout>
    </androidx.cardview.widget.CardView>
    <TextView
        android:id="@+id/tvNombre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center"
        android:text="Quevedo: BN Tour"
        android:textSize="14dp"
        android:textStyle="bold"
        android:layout_marginBottom="30dp"
        android:layout_marginStart="5dp"/>
    <TextView
        android:id="@+id/tvUbicacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center"
        android:text="Palau Sant Jordi"
        android:textSize="12dp"
        android:layout_marginBottom="15dp"
        android:layout_marginStart="5dp"/>
</androidx.cardview.widget.CardView>