<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/navigation_home"> <fragment
    android:id="@+id/navigation_home"
    android:name="com.example.reventa.ui.home.HomeFragment"
    android:label="home"
    tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/navigation_explore"
        android:name="com.example.reventa.ui.explore.ExploreFragment"
        android:label="Explore"
        tools:layout="@layout/fragment_explore" />

    <fragment
        android:id="@+id/navigation_sell"
        android:name="com.example.reventa.ui.sell.SellFragment"
        android:label="Sell"
        tools:layout="@layout/fragment_sell" />

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.reventa.ui.login.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login" />

    <fragment
        android:id="@+id/navigation_profile"
        android:name="com.example.reventa.ui.profile.ProfileFragment"
        android:label="Perfil"
        tools:layout="@layout/fragment_profile" />

    <fragment
        android:id="@+id/ticketsFragment"
        android:name="com.example.reventa.ui.tickets.TicketsFragment"
        android:label="Entradas Disponibles"
        tools:layout="@layout/fragment_tickets" />

    <fragment
        android:id="@+id/paymentFragment"
        android:name="com.example.reventa.ui.payment.PaymentFragment"
        android:label="Pago"
        tools:layout="@layout/fragment_payment">

        <argument
            android:name="idTicket"
            app:argType="long"
            android:defaultValue="-1L" />
        <argument
            android:name="precioTicket"
            app:argType="float"
            android:defaultValue="0.0F" />
    </fragment>

    <fragment
        android:id="@+id/sellTicketFragment"
        android:name="com.example.reventa.ui.sell.SellTicketFragment"
        android:label="Publicar Entrada"
        tools:layout="@layout/fragment_sell_ticket">

        <argument
            android:name="idEvento"
            app:argType="long"
            android:defaultValue="-1L" />
    </fragment>

    <fragment
        android:id="@+id/misEntradasFragment"
        android:name="com.example.reventa.ui.sell.MisEntradasFragment"
        android:label="Mis Entradas"
        tools:layout="@layout/fragment_mis_entradas" />

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.reventa.ui.login.RegisterFragment"
        android:label="Crear Cuenta"
        tools:layout="@layout/fragment_register" />

</navigation>